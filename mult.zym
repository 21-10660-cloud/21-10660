::zilly+

Z => Z abs := fn(Z n) => Z -> if(n < 0, 0 - n, n);

Z => Z => Z mult_rec := fn(Z y) -> fn(Z x) -> if(y < 1, if(y < 0, (0 - x) + mult_rec(y + 1)(x), 0), x + mult_rec(y - 1)(x));

Z => Z => Z mult := fn(Z y) -> fn(Z x) -> if(abs(x) < abs(y), mult_rec(x)(y), mult_rec(y)(x));

mult(3)(4)
mult(10)(2)
mult(0)(5)
mult(7)(0)
mult(0 - 3)(5)
mult(6)(0 - 4)
mult(0 - 4)(0 - 5)
mult(1000)(2)
mult(2)(1000)